# 應用端口
VITE_APP_PORT=3000

# 代理前綴
VITE_APP_BASE_API=/dev-api # 線上

# 接口地址
# VITE_APP_API_URL=https://api.youlai.tech # 線上
VITE_APP_API_URL=http://localhost:3888/adws    # 本地
#VITE_APP_API_URL=https://www.2future.com.tw/prod_dessert_api # 測試機

# WebSocket 端點（不配置則關閉），線上 ws://api.youlai.tech/ws ，本地 ws://localhost:8989/ws
VITE_APP_WS_ENDPOINT=

# 啟用 Mock 服務
VITE_MOCK_DEV_SERVER=true
